{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/start-bot.sh"
          },
          {
            "type": "command",
            "command": "sleep 3 && ${CLAUDE_PLUGIN_ROOT}/discord-notifier.sh > /dev/null 2>&1"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/start-bot.sh"
          },
          {
            "type": "command",
            "command": "sleep 3 && ${CLAUDE_PLUGIN_ROOT}/discord-notifier.sh > /dev/null 2>&1"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/check-status.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/check-status.sh"
          }
        ]
      }
    ]
  }
}
