{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Discord Bot] Starting bot...' && cd CLAUDE_SKILL_DIR && node bot.js status > /dev/null 2>&1 || (nohup node bot.js start > bot.log 2>&1 &)"
          },
          {
            "type": "command",
            "command": "echo '[Discord Bot] Starting notifier in 3s...' && sleep 3 && CLAUDE_SKILL_DIR/discord-notifier.sh > /dev/null 2>&1 &"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Discord Bot] Resuming session...' && cd CLAUDE_SKILL_DIR && node bot.js status > /dev/null 2>&1 || (nohup node bot.js start > bot.log 2>&1 &)"
          },
          {
            "type": "command",
            "command": "sleep 3 && CLAUDE_SKILL_DIR/discord-notifier.sh > /dev/null 2>&1 &"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_SKILL_DIR/bin/check-status.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_SKILL_DIR/bin/check-status.sh"
          }
        ]
      }
    ]
  }
}
